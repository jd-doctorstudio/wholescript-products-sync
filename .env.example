# Postgres logging
DB_NAME=pos_prod
DB_USER=pos_produser
DB_PASSWORD=your_password_here
DB_HOST=127.0.0.1
DB_PORT=5432

# Wholescripts API (test)
WHOLESCRIPTS_API_USERNAME=your_username
WHOLESCRIPTS_API_PASSWORD=your_password
WHOLESCRIPT_API_URL=https://testservices.wholescripts.com/api

# Wholescripts API (production) - uncomment when ready
#WHOLESCRIPTS_API_USERNAME=your_username
#WHOLESCRIPTS_API_PASSWORD=your_production_password
#WHOLESCRIPT_API_URL=https://api.wholescripts.com/api

# WooCommerce REST API
WOO_API_URL=https://store.doctorsstudio.com
WOO_CONSUMER_KEY=ck_your_key
WOO_CONSUMER_SECRET=cs_your_secret
WOOCOMMERCE_API_VERSION=wc/v3

# Custom meta key used for cost price
WOO_COST_META_KEY=_op_cost_price

# ATUM purchase price meta key
ATUM_PURCHASE_PRICE_META_KEY=_atum_purchase_price

# MySQL lookup DB (remote VM via SSH tunnel)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=doctorsstudio

# SSH tunnel to remote VM
SSH_HOST=34.148.82.199
SSH_USER=joy
SSH_KEY_PATH=/var/www/wholescripts-sync/id_servicemenuserver_new
SSH_LOCAL_PORT=33066

# Dry run mode (set to true to skip actual Woo updates)
DRY_RUN=false
