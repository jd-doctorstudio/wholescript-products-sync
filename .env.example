# Postgres logging
DB_NAME=pos_prod
DB_USER=pos_produser
DB_PASSWORD=your_password_here
DB_HOST=127.0.0.1
DB_PORT=5432

# Wholescripts API (test)
WHOLESCRIPTS_API_USERNAME=your_username
WHOLESCRIPTS_API_PASSWORD=your_password
WHOLESCRIPT_API_URL=https://testservices.wholescripts.com/api

# Wholescripts API (production) - uncomment when ready
#WHOLESCRIPTS_API_USERNAME=your_username
#WHOLESCRIPTS_API_PASSWORD=your_production_password
#WHOLESCRIPT_API_URL=https://api.wholescripts.com/api

# WooCommerce REST API
WOO_API_URL=https://store.doctorsstudio.com
WOO_CONSUMER_KEY=ck_your_key
WOO_CONSUMER_SECRET=cs_your_secret
WOOCOMMERCE_API_VERSION=wc/v3

# Custom meta key used for cost price
WOO_COST_META_KEY=_op_cost_price

# MySQL lookup DB (remote VM via SSH tunnel)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=doctorsstudio

# SSH tunnel to remote VM
SSH_HOST=34.148.82.199
SSH_USER=joy
SSH_KEY_PATH=/var/www/wholescripts-sync/id_servicemenuserver_new
SSH_LOCAL_PORT=33066

# Google Sheets (nightly sync report)
GOOGLE_SHEET_ID=your_sheet_id
GOOGLE_SERVICE_ACCOUNT_FILE=doctors-studio-backend-e13229a469d2.json

# Mailgun (primary email sender)
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=doctorsstudio.com
MAILGUN_API_URL=https://api.mailgun.net/v3
MAILGUN_FROM=Wholescripts Sync <sync@doctorsstudio.com>

# SMTP fallback email (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=Support@doctorsstudio.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=Doctors Studio <Support@doctorsstudio.com>

# Email recipients (comma-separated, easy to add more)
EMAIL_RECIPIENTS=joy@doctorsstudio.com

# Feature toggles (ON/OFF)
SHEET_ENABLED=ON
EMAIL_ENABLED=ON

# Dry run mode (set to true to skip actual Woo updates)
DRY_RUN=false
